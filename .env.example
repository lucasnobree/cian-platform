# ═══════════════════════════════════════════════════════════════
# CIAN Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────
# Database (Supabase PostgreSQL) — REQUIRED
# ───────────────────────────────────────────
# Pooled connection string (used by Prisma at runtime)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection string (used by Prisma for migrations)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ───────────────────────────────────────────
# Supabase — REQUIRED
# ───────────────────────────────────────────
# Public URL of your Supabase project (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
# Anon/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
# Service-role key — NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ───────────────────────────────────────────
# Auth (NextAuth) — REQUIRED
# ───────────────────────────────────────────
# Base URL of the application (use http://localhost:3000 for local dev)
NEXTAUTH_URL="http://localhost:3000"
# Random secret for signing JWTs — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ───────────────────────────────────────────
# Trello Integration — OPTIONAL
# ───────────────────────────────────────────
# API key from https://trello.com/power-ups/admin
TRELLO_API_KEY=""
# Token generated via Trello OAuth flow
TRELLO_TOKEN=""

# ───────────────────────────────────────────
# Payment (AbacatePay) — OPTIONAL
# ───────────────────────────────────────────
# API key from AbacatePay dashboard
ABACATEPAY_API_KEY=""
# Webhook secret for verifying payment callbacks
ABACATEPAY_WEBHOOK_SECRET=""

# ───────────────────────────────────────────
# Email (Resend) — OPTIONAL
# ───────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=""
# Verified sender address (must be verified in Resend dashboard)
EMAIL_FROM="noreply@cianart.com.br"

# ───────────────────────────────────────────
# Storage (Cloudflare R2 / Uploadthing) — OPTIONAL
# ───────────────────────────────────────────
# Public URL for accessing stored files
STORAGE_URL=""
# API key or token for uploading files
STORAGE_KEY=""

# ───────────────────────────────────────────
# Monitoring (Sentry) — OPTIONAL
# ───────────────────────────────────────────
# DSN from Sentry project settings
SENTRY_DSN=""
